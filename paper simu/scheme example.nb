Cell[BoxData[{
 RowBox[{"Id", " ", ":=", " ", 
  RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "\n", 
 RowBox[{"Zero", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"One", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], "\n", 
 RowBox[{
  RowBox[{"Unprotect", "[", "CircleTimes", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ClearAll", "[", "CircleTimes", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CircleTimes", ",", "Flat"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"CircleTimes", "[", "args__", "]"}], ":=", 
   RowBox[{"KroneckerProduct", "[", "args", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Protect", "[", "CircleTimes", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.982201658480177*^9, 3.9822016594812393`*^9}},
 CellLabel->
  "In[226]:=",ExpressionUUID->"5ddaf61d-eb44-af4f-a1bd-33905c35de7f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", "=", "8"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ops", "=", 
    RowBox[{"{", 
     RowBox[{"Zero", ",", "One"}], "}"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "build", " ", "all", " ", "pairs", " ", "of", " ", "bit", " ", 
    "positions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pairs", "=", 
    RowBox[{"Subsets", "[", 
     RowBox[{
      RowBox[{"Range", "[", "m", "]"}], ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"build", " ", "matrices"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ma", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "pattern", "}"}], ",", 
          RowBox[{
           RowBox[{"pattern", "=", 
            RowBox[{"ConstantArray", "[", 
             RowBox[{"Id", ",", "m"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"pattern", "[", 
             RowBox[{"[", 
              RowBox[{"pairs", "[", 
               RowBox[{"[", 
                RowBox[{"p", ",", "1"}], "]"}], "]"}], "]"}], "]"}], "=", 
            RowBox[{"ops", "[", 
             RowBox[{"[", "a", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"pattern", "[", 
             RowBox[{"[", 
              RowBox[{"pairs", "[", 
               RowBox[{"[", 
                RowBox[{"p", ",", "2"}], "]"}], "]"}], "]"}], "]"}], "=", 
            RowBox[{"ops", "[", 
             RowBox[{"[", "b", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Diagonal", "@@", 
            RowBox[{"{", 
             RowBox[{"Apply", "[", 
              RowBox[{"CircleTimes", ",", "pattern"}], "]"}], "}"}]}]}]}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"p", ",", 
          RowBox[{"Length", "[", "pairs", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"a", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"b", ",", "2"}], "}"}]}], "]"}], ",", "2"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{"Normalize", "/@", 
    RowBox[{"Transpose", "[", "Ma", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{"Transpose", "[", "M", "]"}]}], ";"}]}], "Input",
